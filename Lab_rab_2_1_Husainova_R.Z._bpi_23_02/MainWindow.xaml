<Window x:Class="Lab_rab_2_1_Husainova_R.Z._bpi_23_02.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сравнение сортировок (Async/Task)" Height="750" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Генерация и отмена -->
        <Label Grid.Row="0" Grid.Column="0" Content="Размер массива:" Margin="3" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ArraySize, UpdateSourceTrigger=PropertyChanged}" Margin="3"/>
        <Button Grid.Row="0" Grid.Column="2" Content="Сгенерировать" Command="{Binding GenerateArrayCommand}" Margin="3"/>
        <Button Grid.Row="0" Grid.Column="3" Content="Прервать всё" Command="{Binding CancelAllCommand}" Margin="3" Width="120"/>

        <!-- Исходный массив -->
        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Text="{Binding OriginalArrayString}" Margin="3" TextWrapping="Wrap"/>

        <!-- Кнопки сортировок -->
        <Button Grid.Row="2" Grid.Column="0" Content="Пузырьковая" Command="{Binding BubbleSortCommand}" Margin="3" Width="120"/>
        <Button Grid.Row="2" Grid.Column="1" Content="Быстрая" Command="{Binding QuickSortCommand}" Margin="3" Width="120"/>
        <Button Grid.Row="2" Grid.Column="2" Content="Вставками" Command="{Binding InsertionSortCommand}" Margin="3" Width="130"/>
        <Button Grid.Row="2" Grid.Column="3" Content="Шейкерная" Command="{Binding ShakerSortCommand}" Margin="3" Width="120"/>
        <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" Content="Запустить все" Command="{Binding RunAllSortsCommand}" Margin="3"/>

        <Label Grid.Row="4" Grid.Column="0" Content="Потоков:" Margin="3"/>
        <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding AvailableThreadCounts}" 
                  SelectedItem="{Binding ThreadCount, UpdateSourceTrigger=PropertyChanged}" Margin="3" Width="100"/>

        <!-- Пузырьковая -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="Пузырьковая:" Margin="3" VerticalAlignment="Center"/>
        <ProgressBar Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" Height="20" Value="{Binding BubbleSortProgress}" Maximum="100" Margin="3"/>
        <TextBlock Grid.Row="7" Grid.Column="3" Text="{Binding BubbleSortProgressText}" Margin="3"/>

        <!-- Быстрая -->
        <TextBlock Grid.Row="8" Grid.Column="0" Text="Быстрая:" Margin="3" VerticalAlignment="Center"/>
        <ProgressBar Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2" Height="20" Value="{Binding QuickSortProgress}" Maximum="100" Margin="3"/>
        <TextBlock Grid.Row="8" Grid.Column="3" Text="{Binding QuickSortProgressText}" Margin="3"/>

        <!-- Вставками -->
        <TextBlock Grid.Row="9" Grid.Column="0" Text="Вставками:" Margin="3" VerticalAlignment="Center"/>
        <ProgressBar Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="2" Height="20" Value="{Binding InsertionSortProgress}" Maximum="100" Margin="3"/>
        <TextBlock Grid.Row="9" Grid.Column="3" Text="{Binding InsertionSortProgressText}" Margin="3"/>

        <!-- Шейкерная -->
        <TextBlock Grid.Row="10" Grid.Column="0" Text="Шейкерная:" Margin="3" VerticalAlignment="Center"/>
        <ProgressBar Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="2" Height="20" Value="{Binding ShakerSortProgress}" Maximum="100" Margin="3"/>
        <TextBlock Grid.Row="10" Grid.Column="3" Text="{Binding ShakerSortProgressText}" Margin="3"/>

        <!-- Результаты -->
        <TextBlock Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="4" Text="{Binding BubbleSortResult}" Margin="3" TextWrapping="Wrap"/>
        <TextBlock Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="4" Text="{Binding QuickSortResult}" Margin="3" TextWrapping="Wrap"/>
        <TextBlock Grid.Row="13" Grid.Column="0" Grid.ColumnSpan="4" Text="{Binding InsertionSortResult}" Margin="3" TextWrapping="Wrap"/>
        <TextBlock Grid.Row="14" Grid.Column="0" Grid.ColumnSpan="4" Text="{Binding ShakerSortResult}" Margin="3" TextWrapping="Wrap"/>

        <TextBlock Grid.Row="15" Grid.Column="0" Grid.ColumnSpan="4" Text="{Binding TotalComparisons}" Margin="3" FontWeight="Bold"/>
        <TextBlock Grid.Row="16" Grid.Column="0" Grid.ColumnSpan="4" Text="{Binding TotalExecutionTime}" Margin="3" FontWeight="Bold"/>
    </Grid>
</Window>